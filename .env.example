# ── Core ─────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── Database (PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql://uptime:uptime@localhost:5432/backend_uptime?schema=public

# ── Redis (sessions cache, rate limiting, BullMQ) ────────────────────
REDIS_URL=redis://localhost:6379

# ── Better Auth ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-32-bytes-minimum-secret
# Public URL of the API service (Better Auth handlers live under /api/auth)
BETTER_AUTH_URL=http://localhost:4000
# Public URL of the web app (trusted origin + email link target)
WEB_URL=http://localhost:3000

# ── API service ──────────────────────────────────────────────────────
API_PORT=4000
# Comma-separated list of additional CORS origins (WEB_URL is always trusted)
CORS_ORIGINS=
# Optional bearer token protecting GET /metrics in production
METRICS_TOKEN=

# ── OAuth providers (leave empty to disable a provider) ──────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email delivery ───────────────────────────────────────────────────
# "ses" (Amazon SES) in production, "smtp" for local dev (Mailpit at
# localhost:1025), or "resend".
EMAIL_PROVIDER=smtp
EMAIL_FROM="Backend Uptime <no-reply@backenduptime.dev>"
RESEND_API_KEY=
SMTP_URL=smtp://localhost:1025

# Amazon SES (EMAIL_PROVIDER=ses). Domain uptimeflow.in must be verified in SES.
# Credentials are OPTIONAL: leave blank in AWS to use the IAM role / instance
# profile (recommended). Set static keys only for local dev or CI.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# For SES: EMAIL_FROM=alerts@uptimeflow.in
EMAIL_MAX_RETRIES=3

# ── Billing (Stripe) ─────────────────────────────────────────────────
# All optional: leave blank to run without billing (local dev / CI). When
# STRIPE_SECRET_KEY is set, STRIPE_WEBHOOK_SECRET must be set too. Use test-mode
# keys (sk_test_…/pk_test_…) outside production. NEVER commit real keys.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# `stripe listen` prints this (whsec_…); in prod it's the dashboard endpoint secret.
STRIPE_WEBHOOK_SECRET=
# Optional: map each plan tier to its Stripe Price/Product id so the seeded plan
# catalog matches the Stripe dashboard. Read by the db seed when present.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_BUSINESS=

# ── Web app (Next.js) ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
# Stripe publishable key exposed to the browser (pk_test_… / pk_live_…).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Comma-separated hostnames the app serves on; any OTHER host is treated as a
# customer custom domain and rewritten to its status page (localhost always
# included). e.g. uptimeflow.app,www.uptimeflow.app
NEXT_PUBLIC_APP_HOSTNAMES=

# ── Observability ────────────────────────────────────────────────────
# When set, OpenTelemetry traces are exported via OTLP/HTTP
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=
